# --- Telegram ---
# Token from @BotFather
BOT_TOKEN=123456:ABC-YourBotTokenHere

# Channel users must be subscribed to before registration.
# PREFER the public @username (e.g. @promotorsshow): the subscribe button links to
# it automatically. A numeric id (e.g. -1004442240963) also works for the check,
# but then set CHANNEL_URL below so the button has a link.
# The bot MUST be an administrator of this channel (else the check always fails).
REQUIRED_CHANNEL=@promotorsshow

# Optional: explicit subscribe-button link. Only needed when REQUIRED_CHANNEL is a
# numeric id (no @username). Example: https://t.me/promotorsshow
CHANNEL_URL=

# --- Shareable ticket (sent to approved participants) ---
# Instagram handle shown on the ticket's "post to Stories and tag us" call to
# action (without or with @). Example: promotorsshow
INSTAGRAM_HANDLE=
# URL the ticket QR code points to. Defaults to the subscribe channel if empty.
# Example: https://instagram.com/promotorsshow
INSTAGRAM_URL=

# Ticket logo. Preferred: commit a transparent PNG to bot/assets/logo.png.
# Alternatively (e.g. on Fly) provide it inline as base64 and it is written to
# that path on startup:  fly secrets set LOGO_BASE64="$(base64 -w0 logo.png)"
LOGO_BASE64=

# Moderation chat where applications are sent with Accept/Reject buttons.
# Add the bot as an admin there. Numeric id, usually negative (e.g. -1001234567890).
ADMIN_CHAT_ID=-1001234567890

# --- Google (service account) ---
# Path to the service-account JSON key file.
GOOGLE_CREDENTIALS_FILE=credentials.json

# Spreadsheet id (from the sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit).
# Leave empty to disable Google Sheets export.
SPREADSHEET_ID=

# Drive folder id where car photos are uploaded (from the folder URL).
# Leave empty to disable photo upload (photo cells will be left blank).
DRIVE_FOLDER_ID=

# --- Admin panel ---
# Password for the web admin panel (single shared password). Leave empty to
# disable the panel entirely. On Fly set it as a secret: fly secrets set ADMIN_PASSWORD=...
ADMIN_PASSWORD=
# Port the panel (and the Fly healthcheck) listens on. Default 8080.
PORT=8080

# Optional: Telegram user ids (comma-separated) allowed to run /diag in a
# private chat with the bot. /diag also works inside the moderation chat.
ADMIN_USER_IDS=

# --- Optional ---
# Require the user to be subscribed to REQUIRED_CHANNEL before registering.
# Set to false to skip the subscription check (handy for demos/testing).
REQUIRE_SUBSCRIPTION=true

# Alternative to GOOGLE_CREDENTIALS_FILE: paste the whole service-account JSON
# inline. Useful on platforms (e.g. Fly.io) that store secrets as env vars, not
# files. If set and the file above is absent, it is written to that path on start.
# GOOGLE_CREDENTIALS_JSON=

# Local paths for runtime data (defaults are fine).
# On Fly.io these are set to the mounted volume (see fly.toml).
DB_PATH=data/pmshow.db
MEDIA_DIR=media
