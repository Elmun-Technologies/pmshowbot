# --- Telegram ---
# Token from @BotFather
BOT_TOKEN=123456:ABC-YourBotTokenHere

# Channel users must be subscribed to before registration.
# Public channel: use @username. Private channel: use its numeric id (e.g. -1001234567890).
REQUIRED_CHANNEL=@promotorsshow

# Moderation chat where applications are sent with Accept/Reject buttons.
# Add the bot as an admin there. Numeric id, usually negative (e.g. -1001234567890).
ADMIN_CHAT_ID=-1001234567890

# --- Google (service account) ---
# Path to the service-account JSON key file.
GOOGLE_CREDENTIALS_FILE=credentials.json

# Spreadsheet id (from the sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit).
# Leave empty to disable Google Sheets export.
SPREADSHEET_ID=

# Drive folder id where car photos are uploaded (from the folder URL).
# Leave empty to disable photo upload (photo cells will be left blank).
DRIVE_FOLDER_ID=

# --- Optional ---
# Local paths for runtime data (defaults are fine).
DB_PATH=data/pmshow.db
MEDIA_DIR=media
